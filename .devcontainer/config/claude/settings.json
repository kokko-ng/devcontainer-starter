{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/vscode/.claude/hooks/git-snapshot.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "/home/vscode/.claude/hooks/guard-git.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/vscode/.claude/hooks/git-snapshot.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/vscode/.claude/hooks/session-git-safety.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "kokko-ai-config@kokko-ng-kokko-cmds": true,
    "kokko-code-quality@kokko-ng-kokko-cmds": true,
    "kokko-git@kokko-ng-kokko-cmds": true,
    "kokko-infra@kokko-ng-kokko-cmds": true,
    "kokko-notifications@kokko-ng-kokko-cmds": true,
    "kokko-safety@kokko-ng-kokko-cmds": false,
    "kokko-validation@kokko-ng-kokko-cmds": true,
    "kokko-viz@kokko-ng-kokko-cmds": true,
    "kokko-janitor@kokko-ng-kokko-janitor": true
  },
  "extraKnownMarketplaces": {
    "kokko-ng-kokko-cmds": {
      "source": {
        "source": "github",
        "repo": "kokko-ng/kokko-cmds"
      }
    },
    "kokko-ng-kokko-janitor": {
      "source": {
        "source": "github",
        "repo": "kokko-ng/kokko-janitor"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
