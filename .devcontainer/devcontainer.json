// devcontainer.json — generic FastAPI + Vue development environment
// See INSTRUCTIONS.md for full setup guide.
{
  "name": "fastapi-vue-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      // Forwarded to the Dockerfile so /Users/<host_user> -> /home/vscode
      // resolves macOS absolute paths in Claude plugin configs.
      "HOST_USER": "${localEnv:USER}"
    }
  },
  "features": {
    // Azure CLI — remove if not using Azure
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    // Docker-in-Docker — a second Docker daemon inside the container.
    // Its image store lives in a named `dind-var-lib-docker-*` volume that
    // survives container removal, is not counted by `docker system df`, and is
    // not reclaimed by `docker image prune`. It therefore grows unnoticed until
    // the Colima VM's disk fills. Prune it from INSIDE the container with
    // `docker system prune -a`, and delete the volume by name when retiring a
    // project. See MANAGING.md -> Disk management.
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true
    }
  },
  "containerEnv": {
    // Adjust the src path if your project layout differs
    "PYTHONPATH": "${containerWorkspaceFolder}/src",
    "UV_LINK_MODE": "copy"
  },
  "initializeCommand": "bash .devcontainer/init-host-certs.sh",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  // FastAPI default port (8000) and Vite dev server (5173)
  "forwardPorts": [8000, 5173],
  "runArgs": [
    // Chromium (used by the Playwright CLI) spawns many short-lived processes.
    // 512 is too low — raise to 1024 to avoid EAGAIN errors.
    "--pids-limit=1024"
  ],
  // Optional mounts — uncomment blocks you need.
  // Shell config and Claude Code settings are bundled in .devcontainer/config/
  // and installed by post-create.sh, so no host mounts are required by default.
  //
  // "mounts": [
  //   // Azure CLI session — keeps you logged in across rebuilds
  //   "source=${localEnv:HOME}/.azure,target=/home/vscode/.azure,type=bind",
  //
  //   // Claude Code state — persists conversation history across rebuilds
  //   // (post-create.sh will not overwrite settings.json if this is mounted)
  //   "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind"
  // ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "Vue.volar",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python"
      }
    }
  }
}
